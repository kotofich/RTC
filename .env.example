DJANGO_SECRET_KEY=replace-with-random-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# DB settings (PostgreSQL)
DB_ENGINE=postgres
POSTGRES_DB=host_reporting
POSTGRES_USER=host_reporting
POSTGRES_PASSWORD=host_reporting
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Optional timezone override
APP_TIME_ZONE=Europe/Moscow
